UserInputService.InputBegan:Connect(function(input, gpe)
    if not scriptRunning then return end
    if isBindingAimbot then
        aimbotKey = (input.UserInputType == Enum.UserInputType.Keyboard) and input.KeyCode or input.UserInputType
        isBindingAimbot = false
        bindAimbotBtn.Text = "Aimbot: " .. tostring(aimbotKey.Name)
        return
    end
    if isBindingESP then
        espKey = (input.UserInputType == Enum.UserInputType.Keyboard) and input.KeyCode or input.UserInputType
        isBindingESP = false
        bindESPBtn.Text = "ESP: " .. tostring(espKey.Name)
        return
    end
    if aimbotKey and (input.KeyCode == aimbotKey or input.UserInputType == aimbotKey) then
        aimbotActive = true
    end
    if espKey and (input.KeyCode == espKey or input.UserInputType == espKey) then
        espEnabled = not espEnabled
        if not espEnabled then 
            for p in pairs(espObjects) do removeESP(p) end
        else 
            for _, p in pairs(Players:GetPlayers()) do createESP(p) end 
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if aimbotKey and (input.KeyCode == aimbotKey or input.UserInputType == aimbotKey) then
        aimbotActive = false
    end
end)

--- LOOP PRINCIPAL ---

RunService.RenderStepped:Connect(function()
    if not scriptRunning then return end
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local mouseLoc = UserInputService:GetMouseLocation()

    if aimbotActive and LocalPlayer.Character then
        local target = nil
        local bestMag = 9999
        
        -- USAMOS EL MULTIPLICADOR ACÁ
        local currentMin = minFOV * fovMultiplier
        local currentMax = maxFOV * fovMultiplier

        for _, p in pairs(Players:GetPlayers()) do
            if isEnemy(p) and p.Character and p.Character:FindFirstChild("Head") then
                local head = p.Character.Head
                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    local pos, vis = Camera:WorldToViewportPoint(head.Position)
                    if vis then
                        local distance = (head.Position - Camera.CFrame.Position).Magnitude
                        local alpha = math.clamp((distance - 5) / (100 - 5), 0, 1)
                        
                        -- Aplicamos los valores multiplicados
                        local dynamicFOV = currentMax + (currentMin - currentMax) * alpha
                        
                        local mag = (Vector2.new(pos.X, pos.Y) - mouseLoc).Magnitude
                        if mag <= dynamicFOV and mag < bestMag then
                            target = pos
                            bestMag = mag
                        end
                    end
                end
            end
        end
        if target then mousemoverel((target.X - mouseLoc.X) * smoothness, (target.Y - mouseLoc.Y) * smoothness) end
    end

    if espEnabled then
        for p, data in pairs(espObjects) do
            if not isEnemy(p) then
                removeESP(p)
            elseif p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local pos, vis = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                data.t.From = Vector2.new(center.X, Camera.ViewportSize.Y - 20)
                if vis and pos.Z > 0 then
                    data.t.To = Vector2.new(pos.X, pos.Y)
                else
                    local x, y = pos.X - center.X, pos.Y - center.Y
                    if pos.Z < 0 then x, y = -x, -y end
                    local ang = math.atan2(y, x)
                    local bX = center.X + math.cos(ang) * 1000
                    local bY = center.Y + math.sin(ang) * 1000
                    data.t.To = Vector2.new(math.clamp(bX, 10, Camera.ViewportSize.X - 10), math.clamp(bY, 10, Camera.ViewportSize.Y - 10))
                end
                data.t.Visible = true
            else 
                removeESP(p) 
            end
        end
    end
end)

--- RE-DETECCIÓN ---
task.spawn(function()
    while task.wait(1) and scriptRunning do
        if espEnabled then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and isEnemy(p) and p.Character and not espObjects[p] then
                    createESP(p)
                end
            end
        end
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    if espEnabled then
        for p in pairs(espObjects) do removeESP(p) end
    end
end)

LocalPlayer.CharacterRemoving:Connect(function()
    task.wait(0.1)
    if espEnabled then
        for p in pairs(espObjects) do removeESP(p) end
    end
end)

local function setup(p)
    p.CharacterAdded:Connect(function()
        if not scriptRunning then return end
        task.wait(0.5)
        if espEnabled and isEnemy(p) then removeESP(p) createESP(p) end
    end)
end
for _, p in pairs(Players:GetPlayers()) do setup(p) end
Players.PlayerAdded:Connect(setup)
