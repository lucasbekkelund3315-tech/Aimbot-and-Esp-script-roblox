--- FUNCIONES AUXILIARES ---

local function darkenColor(color)
    local h, s, v = color:ToHSV()
    return Color3.fromHSV(h, s, v * 0.6)
end

local function cleanup()
    scriptRunning = false
    espEnabled = false
    aimbotActive = false
    for p, _ in pairs(espObjects) do
        if espObjects[p].h then espObjects[p].h:Destroy() end
        if espObjects[p].b then espObjects[p].b:Destroy() end
        if espObjects[p].t then espObjects[p].t:Remove() end
        if espObjects[p].conn then espObjects[p].conn:Disconnect() end
    end
    espObjects = {}
    screenGui:Destroy()
end

closeBtn.MouseButton1Click:Connect(cleanup)

local function getPlayerData(player)
    if not player or not scriptRunning then return "", nil end
    if player.Team and not player.Neutral then
        return player.Team.Name:lower(), player.TeamColor.Color
    end
    for name, val in pairs(player:GetAttributes()) do
        if name:lower() == "team" then return tostring(val):lower(), nil end
    end
    for _, obj in pairs(player:GetChildren()) do
        if obj:IsA("ValueBase") and obj.Name:lower() == "team" then return tostring(obj.Value):lower(), nil end
    end
    return "", nil
end

local function getESPColor(player)
    local teamName, nativeColor = getPlayerData(player)
    if nativeColor then return nativeColor end
    if teamName:find("counter") then return Color3.fromRGB(0, 160, 255)
    elseif teamName:find("terrorist") then return Color3.fromRGB(255, 140, 0) end
    return Color3.fromRGB(255, 0, 0)
end

local function isEnemy(player)
    if not player or player == LocalPlayer then return false end
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("Head") then
        return true
    end
    local myTeamName = getPlayerData(LocalPlayer)
    local targetTeamName = getPlayerData(player)
    if myTeamName == "" or targetTeamName == "" then return true end
    return myTeamName ~= targetTeamName
end

--- MANEJO DE ESP ---

local function removeESP(player)
    if espObjects[player] then
        if espObjects[player].h then espObjects[player].h:Destroy() end
        if espObjects[player].b then espObjects[player].b:Destroy() end
        if espObjects[player].t then espObjects[player].t:Remove() end
        if espObjects[player].conn then espObjects[player].conn:Disconnect() end
        espObjects[player] = nil
    end
end

local function createESP(player)
    if not scriptRunning or not espEnabled or not isEnemy(player) or espObjects[player] then return end
    local char = player.Character
    if not char then return end
    local head = char:WaitForChild("Head", 5)
    if not head then return end

    local color = getESPColor(player)
    local borderCol = darkenColor(color)

    local h = Instance.new("Highlight", char)
    h.FillColor = color
    h.FillTransparency = 0.95 
    h.OutlineColor = borderCol
    h.OutlineTransparency = 0.5

    local b = Instance.new("BillboardGui", head)
    b.Size = UDim2.new(0, 100, 0, 50)
    b.AlwaysOnTop = true
    b.StudsOffset = Vector3.new(0, 3, 0)
    local l = Instance.new("TextLabel", b)
    l.Size = UDim2.new(1, 0, 1, 0)
    l.TextColor3 = color
    l.BackgroundTransparency = 1
    l.Font = Enum.Font.SourceSansBold
    l.TextSize = 14
    l.Text = player.Name

    local tr = Drawing.new("Line")
    tr.Thickness = 2
    tr.Color = color
    tr.Transparency = 1

    local conn = char.ChildRemoved:Connect(function(child)
        if (child == h or child == b) and scriptRunning and espEnabled then
            task.wait(0.2)
            removeESP(player)
            if isEnemy(player) then createESP(player) end
        end
    end)

    espObjects[player] = {h = h, b = b, t = tr, conn = conn}
end

